{
  "name": "payments-qr-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @payments-qr/* dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "infra:init": "pnpm --filter @payments-qr/backend infra:init"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@nestjs/core": "^11.1.27",
      "@types/node": "22.19.0",
      "glob": "^10.5.0",
      "js-yaml": "^4.2.0",
      "lodash": "^4.17.24",
      "multer": "^2.2.0",
      "nanoid": "3.3.13",
      "path-expression-matcher": "1.5.0",
      "picomatch": "^4.0.4",
      "qs": "^6.15.2",
      "tmp": "^0.2.6"
    }
  }
}
