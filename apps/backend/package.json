{
  "name": "@payments-qr/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier \"src/**/*.ts\" \"scripts/**/*.ts\" \"*.json\" --write",
    "format:check": "prettier \"src/**/*.ts\" \"scripts/**/*.ts\" \"*.json\" --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "infra:init": "tsx scripts/init-local-infra.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.705.0",
    "@aws-sdk/client-eventbridge": "^3.705.0",
    "@aws-sdk/client-sqs": "^3.705.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/node": "22.19.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.16.0",
    "globals": "^15.14.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.0",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "@nestjs/core": "^11.1.27",
    "@types/node": "22.19.0",
    "glob": "^10.5.0",
    "js-yaml": "^4.2.0",
    "lodash": "^4.17.24",
    "multer": "^2.2.0",
    "nanoid": "3.3.13",
    "path-expression-matcher": "1.5.0",
    "picomatch": "^4.0.4",
    "qs": "^6.15.2",
    "tmp": "^0.2.6"
  }
}
