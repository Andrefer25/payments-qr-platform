{
  "name": "@payments-qr/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\" --write",
    "format:check": "prettier \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\" --check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"frontend: no tests yet\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
